NODE_ENV=development
PORT=3001

# MySQL/MariaDB — format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/willy_accesoire"

# JWT — générez des secrets aléatoires forts en production (>= 32 caractères)
# ex: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-super-secret-key-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS — origines autorisées (séparées par des virgules)
# Dev : http://localhost:5173
# Prod : le(s) domaine(s) du front, ex: https://willyaccessoire.com
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Store
DEFAULT_CURRENCY="FCFA"
STORE_NAME="Willy Accessoire"

# EdgeStore — clés à récupérer sur https://edgestore.dev/dashboard
EDGE_STORE_ACCESS_KEY="your-edgestore-access-key"
EDGE_STORE_SECRET_KEY="your-edgestore-secret-key"
